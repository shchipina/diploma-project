{
  "frontend/**/*.{ts,tsx,js,jsx}": [
    "prettier --write",
    "eslint --fix --config frontend/eslint.config.js"
  ],
  "backend/src/**/*.{ts,js}": [
    "prettier --write",
    "eslint --fix --config backend/eslint.config.mjs"
  ],
  "backend/test/**/*.{ts,js}": [
    "prettier --write",
    "eslint --fix --config backend/eslint.config.mjs"
  ],
  "*.{json,md,yml,yaml}": ["prettier --write"]
}
