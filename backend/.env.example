DATABASE_URL="postgresql://user:password@localhost:5432/medium_db?schema=public"
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"  # Set to "true" in production with HTTPS

# ===================================
# LOGGING CONFIGURATION
# ===================================
# Рівень логування: error, warn, info, http, debug
# Можна змінювати БЕЗ перекомпіляції для налагодження проблем
# - error: тільки критичні помилки
# - warn: попередження та помилки
# - info: важливі події (логін, CRUD операції) + warn + error
# - http: всі HTTP запити + info + warn + error (для аналізу трафіку)
# - debug: детальна діагностика + всі вище (повільно, тільки для розробки)
LOG_LEVEL="info"

# ПРИМІТКА: Логи зберігаються в директорії backend/logs/ з автоматичною ротацією:
# - logs/app-YYYY-MM-DD.log (всі рівні, 20MB максимум, зберігаються 14 днів)
# - logs/error-YYYY-MM-DD.log (тільки помилки, 20MB максимум, 14 днів)
# - logs/http-YYYY-MM-DD.log (HTTP запити, 20MB, 7 днів)
# При досягненні розміру файл архівується (.gz) та створюється новий.


