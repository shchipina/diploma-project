{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "profile:doctor": "clinic doctor --on-port 'autocannon -c 10 -d 30 localhost:3000/auth/login' -- node dist/main.js",
    "profile:flame": "clinic flame --on-port 'autocannon -c 10 -d 30 localhost:3000/auth/login' -- node dist/main.js",
    "profile:bubbleprof": "clinic bubbleprof --on-port 'autocannon -c 10 -d 30 localhost:3000/auth/login' -- node dist/main.js",
    "profile:heap": "clinic heapprofiler --on-port 'autocannon -c 10 -d 30 localhost:3000/auth/login' -- node dist/main.js",
    "test:load:small": "autocannon -c 10 -d 10 -m POST -H 'Content-Type: application/json' -b '{\"email\":\"test@example.com\",\"password\":\"password123\"}' http://localhost:3000/auth/login",
    "test:load:medium": "autocannon -c 100 -d 30 -m POST -H 'Content-Type: application/json' -b '{\"email\":\"test@example.com\",\"password\":\"password123\"}' http://localhost:3000/auth/login",
    "test:load:large": "autocannon -c 1000 -d 60 -m POST -H 'Content-Type: application/json' -b '{\"email\":\"test@example.com\",\"password\":\"password123\"}' http://localhost:3000/auth/login",
    "db:seed": "ts-node prisma/seed.ts",
    "artillery:small": "artillery run artillery/load-test-small.yml",
    "artillery:medium": "artillery run artillery/load-test-medium.yml",
    "artillery:large": "artillery run artillery/load-test-large.yml",
    "artillery:report": "artillery run artillery/load-test-medium.yml --output artillery/report.json && artillery report artillery/report.json"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nest-winston": "^1.10.2",
    "nestjs-i18n": "^10.6.0",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/instrumentation": "^7.6.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "artillery": "^2.0.30",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "prisma": {
      "seed": "ts-node prisma/seed.ts"
    },
    "testEnvironment": "node"
  }
}
