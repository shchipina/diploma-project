VITE_API_URL=http://localhost:5173

# Рівні: trace, debug, info, warn, error
# - trace: найбільш детальна інформація (всі дії користувача)
# - debug: діагностична інформація (API calls, state changes)
# - info: важливі події (navigation, auth events) - рекомендовано для production
# - warn: потенційні проблеми
# - error: тільки помилки
VITE_LOG_LEVEL=info
